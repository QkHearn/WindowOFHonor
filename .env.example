# PostgreSQL
POSTGRES_USER=honor
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=windowofhonor

# API
JWT_SECRET=change_me_jwt_secret_min_32_chars
CORS_ORIGIN=http://localhost:8080
MCP_SERVICE_TOKEN=change_me_service_token_for_mcp_to_api

# MCP
MCP_API_KEY=change_me_mcp_client_key

# Gateway
NGINX_PORT=8080

# 首次初始化系统管理员（执行 prisma seed 时使用，生产环境请改为强密码）
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=change_me_on_first_deploy
SEED_SUPERADMIN_DISPLAY_NAME=系统管理员
